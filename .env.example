# =============================================================
#  Release Tracker — Secrets & Environment Config
#  File: .env
#  NEVER commit this to Git — add .env to .gitignore
#  Usage: cp .env.example .env  then fill in your values
# =============================================================

# ---- MySQL ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=release_tracker
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_SSL=false
# Set DB_SSL=true for cloud MySQL (PlanetScale, Railway, AWS RDS)

# ---- Server ----
PORT=4000
NODE_ENV=production

# ---- Security ----
# Jenkins uses this to sign webhook calls — must match your Jenkinsfile
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_with_32char_random_hex

# Dashboard uses this key to call the API
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=replace_with_another_32char_random_hex

# ---- Anthropic AI (auto risk scoring + summaries) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- CORS — domains allowed to call this API ----
ALLOWED_ORIGINS=http://localhost:3000,https://your-dashboard-domain.com
